@startuml
skinparam ClassAttributeIconSize 0

' ===== main.java.UI 層 =====
class SwingMain {
    - {static} PREFS: Preferences
    - {static} FLATLAF_AVAILABLE: boolean
    - allRecipeList: AllRecipeList
    - ingredientMaster: IngredientMaster
    - centerPanel: JPanel
    - apiKeyStore: ApiKeyStore
    - currentAiProvider: RecipeAIService.Provider
    - currentModelName: String
    - darkMode: boolean
    - themeButton: JButton
    + showPanel(panel: JPanel): void
    + showWelcome(): void
    + toggleTheme(): void
    - {static} applyTheme(dark: boolean): void
    + getAllRecipeList(): AllRecipeList
    + getIngredientMaster(): IngredientMaster
    + getCurrentAiProvider(): RecipeAIService.Provider
    + setCurrentAiProvider(p): void
    + getCurrentApiKey(): String
    + getApiKeyFor(p): String
    + setApiKeyFor(p, plainKey): void
    + getCurrentModelName(): String
    + setCurrentModelName(m): void
    + {static} main(args: String[]): void
}

note right of SwingMain
  FlatLaf (Light/Dark) を Preferences API
  に永続化。サイドメニューの切替ボタンで
  動的に L&F を入替える
end note

class RegisterRecipePanel {
    - owner: SwingMain
    - editTarget: Recipe
    - titleField: JTextField
    - urlField: JTextField
    - categoryList: JList<RecipeCategory>
    - selectedListModel: DefaultListModel<Ingredient>
    + RegisterRecipePanel(owner)
    + RegisterRecipePanel(owner, editTarget: Recipe)
    - prefillFromRecipe(r: Recipe): void
    - requestAiSuggestion(btn: JButton): void
    - applyAiResult(result: String[]): boolean
    - submitRecipe(): void
}

class ViewRecipePanel {
    - owner: SwingMain
    - buildTitleTab(): JPanel
    - buildIngredientTab(): JPanel
    - buildCategoryTab(): JPanel
    - detailWithEditButton(detail, source): JPanel
}

class DeleteRecipePanel {
}

class DataIOPanel {
    - doExport(owner): void
    - doImport(owner): void
    - wrapText(text): JComponent
}

class IngredientMasterPanel {
    - owner: SwingMain
    - model: DefaultTableModel
    - table: JTable
    - moveSelected(delta: int): void
    - swapRows(a: int, b: int): void
    - refreshRowNumbers(): void
    - save(): void
}

note right of IngredientMasterPanel
  食材一覧をJTableで閲覧・編集。
  カテゴリーをコンボで変更でき、
  ↑/↓で並び順を入れ替えできる。
  保存で database.csv に書き戻す
end note

class SettingsPanel {
    - updateModelCombo(providerCombo, modelCombo): void
}

class Theme <<utility>> {
    + {static} COLOR_PRIMARY: Color
    + {static} COLOR_BG: Color
    + {static} COLOR_SIDE: Color
    + {static} COLOR_TEXT_LIGHT: Color
    + {static} COLOR_DELETE: Color
    + {static} COLOR_AI: Color
    + {static} FONT_MAIN: Font
    + {static} FONT_TITLE: Font
}

class UIComponents <<utility>> {
    + {static} createStyledTextField(): JTextField
    + {static} createStyledRecipeList(model): JList<Recipe>
    + {static} createDetailArea(): JTextArea
    + {static} updateDetailArea(area, recipe): void
    + {static} addLeftAligned(panel, comp): void
    + {static} createPrimaryButton(text): JButton
}

' ===== ドメイン層 =====
enum IngredientCategory {
    VEGETABLE
    MEAT
    SEAFOOD
    CARBOHYDRATE
    FRUIT
    MILK
    PICKLES
    OTHER
    SEASONING
}

enum RecipeCategory {
    RICE
    MEAT
    VEGETABLE
    EGG
    NOODLE
    SOUP
    BREAD
    SEAFOOD
    HOTPOT
    FRIED
    WASHOKU
    YOSHOKU
    CHUKA
    SWEETS
    OTHER
    + getDisplayName(): String
}

class Ingredient {
    - name: String
    - category: IngredientCategory
    + getName(): String
    + getCategory(): IngredientCategory
    + equals(o: Object): boolean
    + hashCode(): int
}

class Recipe {
    - id: long
    - title: String
    - url: String
    - ingredients: ArrayList<Ingredient>
    - categories: EnumSet<RecipeCategory>
    + getId(): long
    + setId(id: long): void
    + getTitle(): String
    + getUrl(): String
    + getIngredients(): ArrayList<Ingredient>
    + getCategories(): EnumSet<RecipeCategory>
}

class IngredientMaster {
    - database: LinkedHashMap<Ingredient, String>
    - loadCsv(): void
    - locateCsv(): File
    - saveCsv(): void
    - appendToCsv(category, name): void
    + searchIngredient(category: IngredientCategory): ArrayList<Ingredient>
    + getAllIngredients(): ArrayList<Ingredient>
    + addIngredient(name: String): Ingredient
    + addIngredient(name, category): Ingredient
    + replaceAll(ordered: List<Ingredient>): void
}

class AllRecipeList {
    - repository: RecipeRepository
    - recipeList: ArrayList<Recipe>
    + addRecipe(recipe: Recipe): void
    + updateRecipe(recipe: Recipe): void
    + deleteRecipe(recipe: Recipe): void
    + getRecipeList(): ArrayList<Recipe>
    + read(): void  // no-op (互換用)
    + write(): void // no-op (互換用)
}

class RecipeIO <<utility>> {
    + {static} FORMAT_VERSION: int = 1
    + {static} exportToJson(recipes: List<Recipe>): String
    + {static} parseFromJson(json, ingredientMaster): List<Recipe>
}

note right of RecipeIO
  外部ライブラリに依存せず純Javaで
  レシピの JSON 入出力を行う。
  バックアップや別端末への移行に利用
end note

' ===== 永続化層 =====
class RecipeRepository {
    - dbPath: String
    - ingredientMaster: IngredientMaster
    + {static} resolveDbPath(): String
    + findAll(): List<Recipe>
    + insert(recipe: Recipe): long
    + update(recipe: Recipe): void
    + delete(id: long): void
    - ensureSchema(): void
    - connect(): Connection
    - lookupIngredient(name: String): Ingredient
}

note right of RecipeRepository
  SQLite (sqlite-jdbc) で
  recipes / recipe_categories /
  recipe_ingredients の3表を管理
end note

' ===== ユーティリティ =====
class WebPageFetcher <<utility>> {
    + {static} fetchSummary(url: String): String
    - {static} readBytes(is, maxBytes): byte[]
    - {static} detectCharset(contentType, snippet): Charset
    - {static} htmlToText(html: String): String
}

class YoutubeMetadataFetcher <<utility>> {
    + {static} fetchSummary(url: String): String
    - {static} extractVideoId(url: String): String
    - {static} fetchTitle(videoUrl: String): String
    - {static} fetchTranscript(videoId: String): String
    - {static} parseTranscriptXml(xml: String): String
}

class WhisperTranscriber <<utility>> {
    + {static} isAvailable(): boolean
    + {static} transcribe(youtubeUrl: String): String
    - {static} runProcess(workingDir, timeout, command...): int
    - {static} locateTool(name: String): Path
    - {static} locateWhisperCli(): Path
    - {static} locateModel(): Path
}

note right of WhisperTranscriber
  YouTube字幕が無い時のフォールバック。
  yt-dlp で 16kHz mono WAV を抽出し、
  whisper.cpp で文字起こし。
  バイナリ&モデルは setup-whisper.bat で
  lib/tools/, lib/models/ に取得する
end note

note right of YoutubeMetadataFetcher
  oEmbed でタイトル取得 +
  watch ページから captionTracks を抽出して
  字幕(timedtext)を取得・テキスト化。
  Ollama等の動画非対応モデル向けに
  プロンプトへ動画情報を注入する
end note

' ===== 暗号化キーストア層 =====
class SecureKeyStore {
    - {static} ALGO: String = "AES/GCM/NoPadding"
    - masterKey: SecretKey
    - random: SecureRandom
    + encrypt(plain: String): String
    + decrypt(ciphertextB64: String): String
    - loadOrCreateMasterKey(): SecretKey
    - {static} keyFilePath(): Path
    - {static} tryRestrictPermissions(p: Path): void
}

note right of SecureKeyStore
  AES-256-GCM。マスタ鍵は
  ~/.recipemanager/master.key に
  パーミッション制限付きで保存。
  初回起動時に乱数生成
end note

class ApiKeyStore {
    - {static} PREF_PREFIX: String = "apiKey."
    - secure: SecureKeyStore
    - prefs: Preferences
    + getKey(provider: Provider): String
    + setKey(provider: Provider, plainKey: String): void
    + clearAll(): void
}

' ===== AI サービス層 =====
class RecipeAIService {
    - selectedProvider: Provider
    - apiKey: String
    - modelName: String
    + setConfig(provider, apiKey, modelName): void
    + suggestRecipe(url, allIngredients): String[]
    + getModelsForProvider(provider): String[]
}

enum "RecipeAIService.Provider" as Provider {
    OPENAI
    GEMINI
    CLAUDE
    OLLAMA
}

abstract class AbstractRecipeAIProvider {
    + {abstract} generateRecipe(apiKey, modelName, url, ings): String[]
    + {abstract} getAvailableModels(): String[]
    # buildPrompt(url, allIngredients): String
    # parseJsonResponse(escapedJson: String): String[]
    # stripBrackets(s: String): String
    # {static} findUnescapedQuote(s, pos): int
    # {static} jsonEscape(s: String): String
    # {static} jsonUnescape(s: String): String
    - extractJsonString(text, key, fallback): String
    - extractJsonStringArray(text, key): String[]
}

class OpenAIProvider {
    + generateRecipe(...): String[]
    + getAvailableModels(): String[]
}

class GeminiProvider {
    + generateRecipe(...): String[]
    + getAvailableModels(): String[]
    - postWithRetry(url, json): String
}

class ClaudeProvider {
    + generateRecipe(...): String[]
    + getAvailableModels(): String[]
}

abstract class OllamaProvider {
    # {static} OLLAMA_URL: String = "http://localhost:11434/api/chat"
    + generateRecipe(apiKey, modelName, url, ings): String[]
}

note right of OllamaProvider
  ローカルLLM Ollama 用の基底クラス。
  /api/chat に format:"json" で問い合わせ、
  各モデルファミリは具象サブクラスで列挙
end note

class LlamaProvider {
    + getAvailableModels(): String[]
}
class GemmaProvider {
    + getAvailableModels(): String[]
}
class MistralProvider {
    + getAvailableModels(): String[]
}
class PhiProvider {
    + getAvailableModels(): String[]
}
class QwenProvider {
    + getAvailableModels(): String[]
}

' ===== 関連 =====
' --- UI層 ---
SwingMain --> AllRecipeList
SwingMain --> IngredientMaster
SwingMain o--> RegisterRecipePanel    : creates >
SwingMain o--> ViewRecipePanel        : creates >
SwingMain o--> DeleteRecipePanel      : creates >
SwingMain o--> SettingsPanel          : creates >
SwingMain o--> DataIOPanel            : creates >
SwingMain o--> IngredientMasterPanel  : creates >
IngredientMasterPanel ..> SwingMain
IngredientMasterPanel ..> IngredientMaster : edits & persists
DataIOPanel ..> SwingMain
DataIOPanel ..> RecipeIO : uses
DataIOPanel ..> UIComponents
ViewRecipePanel ..> RegisterRecipePanel : opens edit >

RegisterRecipePanel ..> SwingMain
ViewRecipePanel     ..> SwingMain
DeleteRecipePanel   ..> SwingMain
SettingsPanel       ..> SwingMain

RegisterRecipePanel ..> RecipeAIService : uses
SettingsPanel       ..> RecipeAIService : uses

RegisterRecipePanel ..> UIComponents
ViewRecipePanel     ..> UIComponents
DeleteRecipePanel   ..> UIComponents
SettingsPanel       ..> UIComponents
UIComponents        ..> Recipe
UIComponents        ..> RecipeCategory

SwingMain           ..> Theme
RegisterRecipePanel ..> Theme
ViewRecipePanel     ..> Theme
DeleteRecipePanel   ..> Theme
SettingsPanel       ..> Theme

RegisterRecipePanel ..> RecipeCategory : multi-select
ViewRecipePanel     ..> RecipeCategory : filter

' --- ドメイン層 ---
AllRecipeList "1" *-- "many" Recipe
Recipe "many" o-- "many" Ingredient
Recipe "many" -- "many" RecipeCategory
Ingredient "many" -- "1" IngredientCategory
IngredientMaster "1" *-- "many" Ingredient

' --- 永続化層 ---
AllRecipeList     --> RecipeRepository : uses
RecipeRepository  ..> IngredientMaster : looks up
RecipeRepository  ..> Recipe           : <<persists to SQLite>>
RecipeRepository  ..> RecipeCategory   : stores enum name

' --- 暗号化キーストア層 ---
SwingMain        --> ApiKeyStore     : holds
ApiKeyStore      --> SecureKeyStore  : delegates encryption
SettingsPanel    ..> ApiKeyStore     : per-provider get/set
RegisterRecipePanel ..> ApiKeyStore  : reads key for current provider

' --- AI層 ---
RecipeAIService     o--> AbstractRecipeAIProvider : delegates to >
RecipeAIService     +-- Provider
AbstractRecipeAIProvider ..> WebPageFetcher : fetches non-YouTube URL
AbstractRecipeAIProvider ..> YoutubeMetadataFetcher : fetches YouTube title+transcript
YoutubeMetadataFetcher   ..> WhisperTranscriber : fallback when no captions
AbstractRecipeAIProvider ..> Ingredient
GeminiProvider      ..> "YouTube file_data" : attaches when youtube URL

' --- 継承 ---
AbstractRecipeAIProvider <|-- OpenAIProvider
AbstractRecipeAIProvider <|-- GeminiProvider
AbstractRecipeAIProvider <|-- ClaudeProvider
AbstractRecipeAIProvider <|-- OllamaProvider
OllamaProvider <|-- LlamaProvider
OllamaProvider <|-- GemmaProvider
OllamaProvider <|-- MistralProvider
OllamaProvider <|-- PhiProvider
OllamaProvider <|-- QwenProvider

@enduml
