@startuml
skinparam ClassAttributeIconSize 0

'  Recipe Manager Pro - 完全版クラス図 (private メンバーを含む全メンバー)
'  ※ 実装(src/main/java 配下)と1:1で対応。
'    匿名 SwingWorker / リスナー等のローカルクラスは図には含めない。

' main.java.UI 層
class SwingMain extends JFrame {
    - {static} PREFS: Preferences
    - {static} PREF_THEME: String
    - {static} FLATLAF_AVAILABLE: boolean
    - allRecipeList: AllRecipeList
    - ingredientMaster: IngredientMaster
    - centerPanel: JPanel
    - apiKeyStore: ApiKeyStore
    - currentAiProvider: RecipeAIService.Provider
    - darkMode: boolean
    - themeButton: JButton
    + SwingMain()
    - buildSideMenu(): JPanel
    - addSideButton(parent: JPanel, text: String, action: ActionListener): void
    - createSideButton(text: String, action: ActionListener): JButton
    - themeButtonLabel(): String
    + toggleTheme(): void
    - {static} applyTheme(dark: boolean): void
    + showPanel(panel: JPanel): void
    + showWelcome(): void
    + getAllRecipeList(): AllRecipeList
    + getIngredientMaster(): IngredientMaster
    + getCurrentAiProvider(): RecipeAIService.Provider
    + setCurrentAiProvider(p: Provider): void
    + getCurrentApiKey(): String
    + getApiKeyFor(p: Provider): String
    + setApiKeyFor(p: Provider, plainKey: String): void
    + getCurrentModelName(): String
    + setCurrentModelName(m: String): void
    + getModelFor(p: Provider): String
    + setModelFor(p: Provider, model: String): void
    + {static} main(args: String[]): void
}

class RegisterRecipePanel extends JPanel {
    - owner: SwingMain
    - editTarget: Recipe
    - titleField: JTextField
    - urlField: JTextField
    - categoryList: JList<RecipeCategory>
    - selectedListModel: DefaultListModel<Ingredient>
    + RegisterRecipePanel(owner: SwingMain)
    + RegisterRecipePanel(owner: SwingMain, editTarget: Recipe)
    - prefillFromRecipe(r: Recipe): void
    - buildHeader(btnAi: JButton): JPanel
    - buildAiButton(): JButton
    - requestAiSuggestion(btnAi: JButton): void
    - applyAiResult(result: String[]): boolean
    - submitRecipe(): void
}

class ViewRecipePanel extends JPanel {
    - owner: SwingMain
    + ViewRecipePanel(owner: SwingMain)
    - detailWithEditButton(detail: JEditorPane, source: JList<Recipe>): JPanel
    - buildTitleTab(): JPanel
    - buildIngredientTab(): JPanel
    - buildCategoryTab(): JPanel
}

class DeleteRecipePanel extends JPanel {
    + DeleteRecipePanel(owner: SwingMain)
}

class DataIOPanel extends JPanel {
    + DataIOPanel(owner: SwingMain)
    - wrapText(text: String): JComponent
    - doExport(owner: SwingMain): void
    - doBatchUrlImport(owner: SwingMain): void
    - runBatchImport(owner: SwingMain, urls: List<String>): void
    - doImport(owner: SwingMain): void
}

class IngredientMasterPanel extends JPanel {
    - {static} COL_NO: int = 0
    - {static} COL_CAT: int = 1
    - {static} COL_NAME: int = 2
    - owner: SwingMain
    - model: DefaultTableModel
    - table: JTable
    + IngredientMasterPanel(owner: SwingMain)
    - moveSelected(delta: int): void
    - swapRows(a: int, b: int): void
    - refreshRowNumbers(): void
    - buildUnifyButton(): JButton
    - detectAndUnifyVariants(): void
    - handleDetectedGroups(groups): void
    - reloadTable(): void
    - save(): void
}

class SettingsPanel extends JPanel {
    + SettingsPanel(owner: SwingMain)
}

class Theme <<utility>> {
    + {static} COLOR_PRIMARY: Color
    + {static} COLOR_BG: Color
    + {static} COLOR_SIDE: Color
    + {static} COLOR_TEXT_LIGHT: Color
    + {static} COLOR_DELETE: Color
    + {static} COLOR_AI: Color
    + {static} FONT_MAIN: Font
    + {static} FONT_TITLE: Font
    - Theme()
}

class UIComponents <<utility>> {
    + {static} createStyledTextField(): JTextField
    + {static} attachContextMenu(comp: JTextComponent): void
    + {static} createStyledRecipeList(model: DefaultListModel<Recipe>): JList<Recipe>
    + {static} createDetailArea(): JEditorPane
    + {static} updateDetailArea(area: JEditorPane, recipe: Recipe): void
    - {static} escapeHtml(s: String): String
    - {static} escapeAttr(s: String): String
    - {static} toHex(c: Color): String
    + {static} addLeftAligned(panel: JPanel, comp: JComponent): void
    + {static} createPrimaryButton(text: String): JButton
    - UIComponents()
}

' ===== ドメイン層 =====
enum IngredientCategory {
    VEGETABLE
    MEAT
    SEAFOOD
    CARBOHYDRATE
    FRUIT
    MILK
    PICKLES
    SEASONING
    OTHER
}

enum RecipeCategory {
    RICE
    MEAT
    VEGETABLE
    EGG
    NOODLE
    SOUP
    BREAD
    SEAFOOD
    HOTPOT
    FRIED
    WASHOKU
    YOSHOKU
    CHUKA
    SWEETS
    OTHER
    --
    - displayName: String
    + getDisplayName(): String
    + toString(): String
}

class Ingredient {
    - name: String
    - category: IngredientCategory
    + Ingredient(name: String, category: IngredientCategory)
    + getName(): String
    + getCategory(): IngredientCategory
    + toString(): String
    + equals(o: Object): boolean
    + hashCode(): int
}

class Recipe {
    - id: long
    - title: String
    - url: String
    - ingredients: ArrayList<Ingredient>
    - categories: EnumSet<RecipeCategory>
    + Recipe(title: String, url: String, ingredients: ArrayList<Ingredient>, categories: EnumSet<RecipeCategory>)
    + getId(): long
    + setId(id: long): void
    + getTitle(): String
    + getUrl(): String
    + getIngredients(): ArrayList<Ingredient>
    + getCategories(): EnumSet<RecipeCategory>
}

class IngredientMaster {
    - database: LinkedHashMap<Ingredient, String>
    + IngredientMaster()
    - loadCsv(): void
    - locateCsv(): File
    + searchIngredient(category: IngredientCategory): ArrayList<Ingredient>
    + getAllIngredients(): ArrayList<Ingredient>
    + replaceAll(ordered: List<Ingredient>): void
    - saveCsv(): void
    + addIngredient(name: String): Ingredient
    + addIngredient(name: String, category: IngredientCategory): Ingredient
    - appendToCsv(category: IngredientCategory, name: String): void
}

class AllRecipeList {
    - repository: RecipeRepository
    - recipeList: ArrayList<Recipe>
    + AllRecipeList(ingredientMaster: IngredientMaster)
    + getRecipeList(): ArrayList<Recipe>
    + addRecipe(recipe: Recipe): void
    + deleteRecipe(recipe: Recipe): void
    + updateRecipe(recipe: Recipe): void
}

class RecipeIO <<utility>> {
    + {static} FORMAT_VERSION: int = 1
    - RecipeIO()
    + {static} exportToJson(recipes: List<Recipe>): String
    - {static} serializeRecipe(r: Recipe, indent: String): String
    + {static} parseFromJson(json: String, ingredientMaster: IngredientMaster): List<Recipe>
    - {static} parseRecipe(obj: String, im: IngredientMaster): Recipe
    - {static} lookupIngredient(im: IngredientMaster, name: String): Ingredient
    - {static} extractJsonString(obj: String, key: String): String
    - {static} extractJsonStringArray(obj: String, key: String): String[]
    - {static} findUnescapedQuote(s: String, pos: int): int
    - {static} findMatchingBracket(s: String, start: int, open: char, close: char): int
    - {static} jsonEscape(s: String): String
    - {static} jsonUnescape(s: String): String
}

class BatchUrlImporter <<utility>> {
    - BatchUrlImporter()
    + {static} readUrls(file: Path): List<String>
    + {static} importAll(urls: List<String>, aiService: RecipeAIService, master: IngredientMaster, recipeList: AllRecipeList, onProgress: Consumer<Progress>, cancelCheck: BooleanSupplier): Result
    - {static} buildRecipe(result: String[], url: String, master: IngredientMaster): Recipe
}

enum "BatchUrlImporter.Status" as BatchStatus {
    PROCESSING
    SUCCEEDED
    FAILED
    SKIPPED_DUPLICATE
}

class "BatchUrlImporter.Result" as BatchResult {
    + {final} succeeded: int
    + {final} failed: int
    + {final} skipped: int
    + {final} total: int
    + Result(succeeded: int, failed: int, skipped: int, total: int)
}

class "BatchUrlImporter.Progress" as BatchProgress {
    + {final} index: int
    + {final} total: int
    + {final} url: String
    + {final} status: Status
    + Progress(index: int, total: int, url: String, status: Status)
}

BatchUrlImporter +-- BatchStatus
BatchUrlImporter +-- BatchResult
BatchUrlImporter +-- BatchProgress
BatchProgress --> BatchStatus

class IngredientNormalizer <<utility>> {
    - IngredientNormalizer()
    + {static} buildPrompt(names: List<String>): String
    + {static} parseGroups(json: String): List<VariantGroup>
    + {static} apply(groups: List<VariantGroup>, master: IngredientMaster, recipeList: AllRecipeList): ApplyResult
}

class "IngredientNormalizer.VariantGroup" as VariantGroup {
    + {final} canonical: String
    + {final} variants: List<String>
}

class "IngredientNormalizer.ApplyResult" as ApplyResult {
    + {final} mergedNames: int
    + {final} updatedRecipes: int
}

note right of IngredientNormalizer
  食材名の表記ゆれをAIで統一する処理。
  buildPrompt→(RecipeAIService.chat)→parseGroups で
  検出し、apply でマスタとレシピを書き換える。
  AI実装には依存せず文字列入出力のみを扱う。
end note

IngredientNormalizer +-- VariantGroup
IngredientNormalizer +-- ApplyResult
IngredientNormalizer ..> IngredientMaster : replaceAll で集約
IngredientNormalizer ..> AllRecipeList : updateRecipe で置換
RecipeAIService ..> IngredientNormalizer : buildPrompt / parseGroups
IngredientMasterPanel ..> RecipeAIService : 表記ゆれ検出
IngredientMasterPanel ..> IngredientNormalizer : 統一を適用

' ===== 永続化層 =====
class RecipeRepository {
    - {final} dbPath: String
    - {final} ingredientMaster: IngredientMaster
    + RecipeRepository(dbPath: String, ingredientMaster: IngredientMaster)
    + {static} resolveDbPath(): String
    - connect(): Connection
    - ensureSchema(): void
    + findAll(): List<Recipe>
    + insert(recipe: Recipe): long
    + update(recipe: Recipe): void
    + delete(id: long): void
    - lookupIngredient(name: String): Ingredient
}

class "RecipeRepository.RecipeBuilder" as RecipeBuilder {
    ~ {final} id: long
    ~ {final} title: String
    ~ {final} url: String
    ~ {final} ingredients: ArrayList<Ingredient>
    ~ {final} categories: EnumSet<RecipeCategory>
}

RecipeRepository +-- RecipeBuilder

' ===== ユーティリティ =====
class WebPageFetcher <<utility>> {
    - {static} MAX_BYTES: int = 200_000
    - {static} MAX_TEXT_LENGTH: int = 3000
    - {static} CONNECT_TIMEOUT_MS: int = 5000
    - {static} READ_TIMEOUT_MS: int = 5000
    - WebPageFetcher()
    + {static} fetchSummary(url: String): String
    - {static} readBytes(is: InputStream, maxBytes: int): byte[]
    - {static} detectCharset(contentType: String, htmlSnippet: String): Charset
    - {static} htmlToText(html: String): String
}

class YoutubeMetadataFetcher <<utility>> {
    - {static} CONNECT_TIMEOUT_MS: int = 5000
    - {static} READ_TIMEOUT_MS: int = 8000
    - {static} MAX_TRANSCRIPT_LENGTH: int = 4000
    - {static} DESCRIPTION_SUFFICIENT_THRESHOLD: int = 150
    - YoutubeMetadataFetcher()
    + {static} fetchSummary(url: String): String
    + {static} fetchSummary(url: String, ingredientNames: List<String>): String
    - {static} stripUrls(s: String): String
    - {static} containsAnyIngredient(text: String, ingredientNames: List<String>): boolean
    - {static} extractDescription(html: String): String
    - {static} extractTranscript(html: String): String
    - {static} extractVideoId(url: String): String
    - {static} fetchTitle(videoUrl: String): String
    - {static} parseTranscriptXml(xml: String): String
    - {static} httpGet(url: String, accept: String): String
    - {static} findUnescapedQuote(s: String, pos: int): int
    - {static} jsonUnescape(s: String): String
}

class WhisperTranscriber <<utility>> {
    - {static} TRANSCRIBE_TIMEOUT_SEC: long = 600
    - WhisperTranscriber()
    - {static} isWindows(): boolean
    - {static} executableName(baseName: String): String
    + {static} isAvailable(): boolean
    + {static} transcribe(youtubeUrl: String): String
    - {static} runProcess(workingDir: Path, timeoutSec: long, command: String...): int
    - {static} locateTool(baseName: String): Path
    - {static} findOnSystemPath(exeName: String): Path
    - {static} locateWhisperCli(): Path
    - {static} locateBundledTool(baseName: String): Path
    - {static} locateModel(): Path
    - {static} toolsDirCandidates(): Path[]
    - {static} modelDirCandidates(): Path[]
    - {static} deleteRecursively(root: Path): void
}

' 暗号化層
class SecureKeyStore {
    - {static} ALGO: String = "AES/GCM/NoPadding"
    - {static} GCM_TAG_BITS: int = 128
    - {static} IV_BYTES: int = 12
    - {static} KEY_BYTES: int = 32
    - {final} masterKey: SecretKey
    - {final} random: SecureRandom
    + SecureKeyStore()
    - {static} keyFilePath(): Path
    - loadOrCreateMasterKey(): SecretKey
    - {static} tryRestrictPermissions(p: Path): void
    + encrypt(plain: String): String
    + decrypt(ciphertextB64: String): String
}

class ApiKeyStore {
    - {static} PREF_PREFIX: String = "apiKey."
    - {final} secure: SecureKeyStore
    - {final} prefs: Preferences
    + ApiKeyStore(secure: SecureKeyStore, prefs: Preferences)
    + getKey(provider: Provider): String
    + setKey(provider: Provider, plainKey: String): void
    + clearAll(): void
}

'AI制御層
class RecipeAIService {
    - selectedProvider: Provider
    - apiKey: String
    - modelName: String
    + setConfig(provider: Provider, apiKey: String, modelName: String): void
    + suggestRecipe(url: String, allIngredients: ArrayList<Ingredient>): String[]
    + detectIngredientVariants(names: List<String>): List<VariantGroup>
    + getModelsForProvider(provider: Provider): String[]
    + fetchModelsForProvider(provider: Provider, apiKey: String): String[]
    - {static} createProvider(provider: Provider, modelName: String): AbstractRecipeAIProvider
    - {static} ollamaProviderForModel(modelName: String): OllamaProvider
    - {static} ollamaSubclasses(): OllamaProvider[]
}

enum "RecipeAIService.Provider" as Provider {
    OPENAI
    GEMINI
    CLAUDE
    OLLAMA
}

abstract class AbstractRecipeAIProvider {
    + {abstract} generateRecipe(apiKey: String, modelName: String, url: String, allIngredients: ArrayList<Ingredient>): String[]
    + {abstract} chat(apiKey: String, modelName: String, prompt: String): String
    + {abstract} getAvailableModels(): String[]
    + fetchAvailableModels(apiKey: String): String[]
    # buildPrompt(url: String, allIngredients: ArrayList<Ingredient>): String
    # parseJsonResponse(escapedJsonText: String): String[]
    - extractJsonString(text: String, key: String, fallback: String): String
    - extractJsonStringArray(text: String, key: String): String[]
    # {static} findUnescapedQuote(s: String, pos: int): int
    # {static} jsonEscape(s: String): String
    # {static} jsonUnescape(s: String): String
    # {static} extractAllJsonStrings(json: String, key: String): List<String>
    # stripBrackets(s: String): String
    # {static} readStream(stream: InputStream): String
    # extractAndParse(jsonRes: String, contentKey: String): String[]
    # extractRawContent(jsonRes: String, contentKey: String): String
    - extractContentField(jsonRes: String, contentKey: String): String
}

note right of AbstractRecipeAIProvider
  generateRecipe はレシピ生成専用。
  chat は任意プロンプト→モデル本文(JSON)を返す
  汎用呼び出しで、表記ゆれ検出などに使う。
  各具象は post/buildBody でHTTPを共通化。
end note

class OpenAIProvider {
    + generateRecipe(...): String[]
    + chat(apiKey, modelName, prompt): String
    + fetchAvailableModels(apiKey: String): String[]
    - {static} buildBody(modelName: String, prompt: String): String
    - post(apiKey: String, body: String): String
    - {static} isChatModel(id: String): boolean
    + getAvailableModels(): String[]
}

class GeminiProvider {
    + generateRecipe(...): String[]
    + chat(apiKey, modelName, prompt): String
    - postWithRetry(urlStr: String, json: String): String
    ~ {static} canonicalYoutubeUrl(url: String): String
    - {static} extractYoutubeVideoId(url: String): String
    + fetchAvailableModels(apiKey: String): String[]
    + getAvailableModels(): String[]
}

class ClaudeProvider {
    + generateRecipe(...): String[]
    + chat(apiKey, modelName, prompt): String
    - {static} buildBody(modelName: String, prompt: String, maxTokens: int): String
    - post(apiKey: String, body: String): String
    + fetchAvailableModels(apiKey: String): String[]
    + getAvailableModels(): String[]
}

abstract class OllamaProvider {
    # {static} OLLAMA_URL: String = "http://localhost:11434/api/chat"
    # {static} OLLAMA_TAGS_URL: String = "http://localhost:11434/api/tags"
    + fetchAvailableModels(apiKey: String): String[]
    + generateRecipe(apiKey: String, modelName: String, url: String, ings: ArrayList<Ingredient>): String[]
    + chat(apiKey, modelName, prompt): String
    - post(modelName: String, prompt: String): String
}

class LlamaProvider {
    + getAvailableModels(): String[]
}
class GemmaProvider {
    + getAvailableModels(): String[]
}
class MistralProvider {
    + getAvailableModels(): String[]
}
class PhiProvider {
    + getAvailableModels(): String[]
}
class QwenProvider {
    + getAvailableModels(): String[]
}

' UI層
SwingMain --> AllRecipeList
SwingMain --> IngredientMaster
SwingMain o--> RegisterRecipePanel    : creates >
SwingMain o--> ViewRecipePanel        : creates >
SwingMain o--> DeleteRecipePanel      : creates >
SwingMain o--> SettingsPanel          : creates >
SwingMain o--> DataIOPanel            : creates >
SwingMain o--> IngredientMasterPanel  : creates >
IngredientMasterPanel ..> SwingMain
IngredientMasterPanel ..> IngredientMaster : edits & persists
DataIOPanel ..> SwingMain
DataIOPanel ..> RecipeIO : uses
DataIOPanel ..> BatchUrlImporter : URL一括取込
DataIOPanel ..> RecipeAIService  : 一括取込時に呼び出し
DataIOPanel ..> UIComponents
BatchUrlImporter ..> RecipeAIService
BatchUrlImporter ..> IngredientMaster
BatchUrlImporter ..> AllRecipeList
ViewRecipePanel ..> RegisterRecipePanel : opens edit >

RegisterRecipePanel ..> SwingMain
ViewRecipePanel     ..> SwingMain
DeleteRecipePanel   ..> SwingMain
SettingsPanel       ..> SwingMain

RegisterRecipePanel ..> RecipeAIService : uses
SettingsPanel       ..> RecipeAIService : uses

RegisterRecipePanel ..> UIComponents
ViewRecipePanel     ..> UIComponents
DeleteRecipePanel   ..> UIComponents
SettingsPanel       ..> UIComponents
UIComponents        ..> Recipe
UIComponents        ..> RecipeCategory

SwingMain           ..> Theme
RegisterRecipePanel ..> Theme
ViewRecipePanel     ..> Theme
DeleteRecipePanel   ..> Theme
SettingsPanel       ..> Theme

RegisterRecipePanel ..> RecipeCategory : multi-select
ViewRecipePanel     ..> RecipeCategory : filter

' --- ドメイン層 ---
AllRecipeList "1" *-- "many" Recipe
Recipe "many" o-- "many" Ingredient
Recipe "many" -- "many" RecipeCategory
Ingredient "many" -- "1" IngredientCategory
IngredientMaster "1" *-- "many" Ingredient

' --- 永続化層 ---
AllRecipeList     --> RecipeRepository : uses
RecipeRepository  ..> IngredientMaster : looks up
RecipeRepository  ..> Recipe           : <<persists to SQLite>>
RecipeRepository  ..> RecipeCategory   : stores enum name

' --- 暗号化キーストア層 ---
SwingMain        --> ApiKeyStore     : holds
ApiKeyStore      --> SecureKeyStore  : delegates encryption
SettingsPanel    ..> ApiKeyStore     : per-provider get/set
RegisterRecipePanel ..> ApiKeyStore  : reads key for current provider

' --- AI層 ---
RecipeAIService     o--> AbstractRecipeAIProvider : delegates to >
RecipeAIService     +-- Provider
AbstractRecipeAIProvider ..> WebPageFetcher : fetches non-YouTube URL
AbstractRecipeAIProvider ..> YoutubeMetadataFetcher : fetches YouTube title+transcript
YoutubeMetadataFetcher   ..> WhisperTranscriber : fallback when no captions
AbstractRecipeAIProvider ..> Ingredient
GeminiProvider      ..> "YouTube file_data" : attaches when youtube URL

' --- 継承 ---
AbstractRecipeAIProvider <|-- OpenAIProvider
AbstractRecipeAIProvider <|-- GeminiProvider
AbstractRecipeAIProvider <|-- ClaudeProvider
AbstractRecipeAIProvider <|-- OllamaProvider
OllamaProvider <|-- LlamaProvider
OllamaProvider <|-- GemmaProvider
OllamaProvider <|-- MistralProvider
OllamaProvider <|-- PhiProvider
OllamaProvider <|-- QwenProvider

@enduml
